{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-discovery.dev/schemas/acm.schema.json",
  "title": "Agent-Capability Manifest",
  "description": "Machine-readable service metadata that lets AI agents discover, evaluate, price, and invoke business capabilities.",
  "type": "object",
  "required": [
    "acmVersion",
    "namespace",
    "publisher",
    "capabilities",
    "endpoints"
  ],
  "additionalProperties": false,
  "properties": {
    "acmVersion": {
      "type": "string",
      "pattern": "^0\\.1\\.\\d+$",
      "description": "Version of the ACM spec used by this manifest."
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$",
      "description": "Reverse-DNS namespace controlled by the publisher, for example com.acme.procurement."
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 600
    },
    "publisher": {
      "type": "object",
      "required": [
        "name",
        "domain"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2
        },
        "domain": {
          "type": "string",
          "pattern": "^[a-z0-9.-]+\\.[a-z]{2,}$"
        },
        "did": {
          "type": "string",
          "pattern": "^did:[a-z0-9]+:.+"
        },
        "contact": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "tags",
          "inputSchema",
          "outputSchema"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{2,80}$"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120
          },
          "description": {
            "type": "string",
            "minLength": 20,
            "maxLength": 1000
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]{1,40}$"
            },
            "uniqueItems": true
          },
          "inputSchema": {
            "type": "object",
            "description": "JSON Schema describing invocation input."
          },
          "outputSchema": {
            "type": "object",
            "description": "JSON Schema describing invocation output."
          },
          "execution": {
            "type": "object",
            "description": "How an agent can execute this capability against the business API.",
            "required": [
              "method",
              "path",
              "mode"
            ],
            "additionalProperties": false,
            "properties": {
              "method": {
                "type": "string",
                "enum": [
                  "GET",
                  "POST",
                  "PUT",
                  "PATCH",
                  "DELETE"
                ]
              },
              "path": {
                "type": "string",
                "pattern": "^/"
              },
              "mode": {
                "type": "string",
                "enum": [
                  "read",
                  "quote",
                  "transaction",
                  "workflow"
                ]
              },
              "requiresConfirmation": {
                "type": "boolean",
                "description": "Whether a human or delegated mandate must approve before execution."
              },
              "idempotencyKeyRequired": {
                "type": "boolean",
                "description": "Whether write calls require an idempotency key."
              }
            }
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "intent",
                "input"
              ],
              "additionalProperties": false,
              "properties": {
                "intent": {
                  "type": "string",
                  "minLength": 10
                },
                "input": {
                  "type": "object"
                }
              }
            }
          },
          "mediaTypes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "application/json"
            ]
          }
        }
      }
    },
    "pricing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "enum": [
            "free",
            "subscription",
            "usage",
            "quote"
          ]
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "plans": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "price"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "price": {
                "type": "number",
                "minimum": 0
              },
              "unit": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "trust": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verificationStatus": {
          "type": "string",
          "enum": [
            "unverified",
            "self-attested",
            "verified"
          ]
        },
        "credentials": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "type",
              "issuer",
              "url"
            ],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string"
              },
              "issuer": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        "reputation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 5
            },
            "transactionCount": {
              "type": "integer",
              "minimum": 0
            },
            "disputeRate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "endpoints": {
      "type": "object",
      "required": [
        "baseUrl"
      ],
      "additionalProperties": false,
      "properties": {
        "baseUrl": {
          "type": "string",
          "format": "uri"
        },
        "manifestUrl": {
          "type": "string",
          "format": "uri"
        },
        "protocols": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "type",
              "url"
            ],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "rest",
                  "mcp",
                  "a2a"
                ]
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        "auth": {
          "type": "object",
          "required": [
            "type"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "none",
                "apiKey",
                "oauth2",
                "did-signature"
              ]
            },
            "authorizationUrl": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "rateLimits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requestsPerMinute": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "sla": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "availability": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "p95LatencyMs": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  }
}
