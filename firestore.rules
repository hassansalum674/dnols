rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /submissions/{submissionId} {
      allow create: if isValidSubmission();
      allow read, update, delete: if false;
    }

    match /dealRequests/{dealRequestId} {
      allow create: if isValidDealRequest();
      allow read, update, delete: if false;
    }

    match /dealApprovals/{approvalId} {
      allow create: if isValidDealApproval();
      allow read, update, delete: if false;
    }

    match /auditEvents/{eventId} {
      allow create: if isValidAuditEvent();
      allow read, update, delete: if false;
    }

    match /deals/{dealId} {
      allow read, write: if false;
    }

    match /dealPhoneIndex/{phoneIndexId} {
      allow read, write: if false;
    }

    match /businessAccounts/{ownerUid} {
      allow read: if isOwner(ownerUid);
      allow create: if isOwner(ownerUid)
        && request.resource.data.ownerUid == ownerUid
        && request.resource.data.email is string
        && request.resource.data.businessName is string
        && request.resource.data.status in ['pending_review', 'active', 'paused']
        && request.resource.data.plan in ['free', 'basic', 'professional', 'enterprise'];
      allow update: if isOwner(ownerUid)
        && resource.data.ownerUid == ownerUid
        && request.resource.data.ownerUid == ownerUid;
      allow delete: if false;
    }

    match /businessProfiles/{ownerUid} {
      allow read: if isOwner(ownerUid);
      allow create: if isOwner(ownerUid)
        && request.resource.data.ownerUid == ownerUid
        && request.resource.data.businessName is string
        && request.resource.data.status in ['draft', 'pending_review', 'verified', 'published', 'paused'];
      allow update: if isOwner(ownerUid)
        && resource.data.ownerUid == ownerUid
        && request.resource.data.ownerUid == ownerUid;
      allow delete: if false;

      match /inbox/{dealId} {
        allow read: if isOwner(ownerUid);
        allow create: if isOwner(ownerUid) && request.resource.data.ownerUid == ownerUid;
        allow update: if isOwner(ownerUid) && resource.data.ownerUid == ownerUid && request.resource.data.ownerUid == ownerUid;
        allow delete: if false;
      }

      match /sentRequests/{dealId} {
        allow read: if isOwner(ownerUid);
        allow create: if isOwner(ownerUid) && request.resource.data.ownerUid == ownerUid;
        allow update: if isOwner(ownerUid) && resource.data.ownerUid == ownerUid && request.resource.data.ownerUid == ownerUid;
        allow delete: if false;
      }

      match /orders/{orderId} {
        allow read: if isOwner(ownerUid);
        allow create: if isOwner(ownerUid) && request.resource.data.ownerUid == ownerUid;
        allow update: if isOwner(ownerUid) && resource.data.ownerUid == ownerUid && request.resource.data.ownerUid == ownerUid;
        allow delete: if false;

        match /messages/{messageId} {
          allow read: if isOwner(ownerUid);
          allow create: if isOwner(ownerUid)
            && request.resource.data.ownerUid == ownerUid
            && request.resource.data.orderId == orderId;
          allow update, delete: if false;
        }
      }

      match /approvals/{approvalId} {
        allow read: if isOwner(ownerUid);
        allow create: if isOwner(ownerUid) && request.resource.data.ownerUid == ownerUid;
        allow update: if isOwner(ownerUid) && resource.data.ownerUid == ownerUid && request.resource.data.ownerUid == ownerUid;
        allow delete: if false;
      }

      match /auditEvents/{eventId} {
        allow read: if isOwner(ownerUid);
        allow create: if isOwner(ownerUid) && request.resource.data.ownerUid == ownerUid;
        allow update, delete: if false;
      }

      match /agentRuns/{runId} {
        allow read: if isOwner(ownerUid);
        allow create: if isOwner(ownerUid) && request.resource.data.ownerUid == ownerUid;
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }

    function isOwner(ownerUid) {
      return request.auth != null && request.auth.uid == ownerUid;
    }

    function isValidSubmission() {
      return request.resource.data.keys().hasOnly([
          'schemaVersion',
          'source',
          'status',
          'input',
          'manifest',
          'agentProfileDraft',
          'readinessScore',
          'validation',
          'createdAt',
          'submittedAtClient',
          'page',
          'userAgent'
        ])
        && request.resource.data.schemaVersion == 1
        && request.resource.data.source == 'onboarding'
        && request.resource.data.status == 'new'
        && request.resource.data.input is map
        && request.resource.data.manifest is map
        && request.resource.data.agentProfileDraft is map
        && request.resource.data.validation is map
        && request.resource.data.readinessScore is int
        && request.resource.data.readinessScore >= 0
        && request.resource.data.readinessScore <= 100
        && request.resource.data.createdAt is timestamp
        && request.resource.data.submittedAtClient is string
        && request.resource.data.submittedAtClient.size() <= 40
        && request.resource.data.page is string
        && request.resource.data.page.size() <= 300
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 240;
    }

    function isValidDealRequest() {
      return request.resource.data.keys().hasOnly([
          'schemaVersion',
          'source',
          'status',
          'requester',
          'target',
          'capability',
          'requirements',
          'budget',
          'riskControls',
          'dealSummary',
          'approval',
          'createdAt',
          'submittedAtClient',
          'page',
          'userAgent'
        ])
        && request.resource.data.schemaVersion == 1
        && request.resource.data.source == 'deal-request'
        && request.resource.data.status == 'pending_human_approval'
        && request.resource.data.requester is map
        && request.resource.data.target is map
        && request.resource.data.capability is map
        && request.resource.data.requirements is map
        && request.resource.data.budget is map
        && request.resource.data.riskControls is map
        && request.resource.data.riskControls.dailyRequestCount is int
        && request.resource.data.riskControls.dailyRequestCount >= 1
        && request.resource.data.riskControls.dailyRequestCount <= 5
        && request.resource.data.riskControls.dailyRequestLimit == 5
        && request.resource.data.riskControls.manualReviewRequired == true
        && request.resource.data.riskControls.manualReviewReason is string
        && request.resource.data.riskControls.manualReviewReason.size() <= 80
        && request.resource.data.riskControls.firstDealsThreshold == 3
        && request.resource.data.dealSummary is string
        && request.resource.data.dealSummary.size() >= 20
        && request.resource.data.dealSummary.size() <= 1200
        && request.resource.data.approval is map
        && request.resource.data.createdAt is timestamp
        && request.resource.data.submittedAtClient is string
        && request.resource.data.submittedAtClient.size() <= 40
        && request.resource.data.page is string
        && request.resource.data.page.size() <= 300
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 240;
    }

    function isValidDealApproval() {
      return request.resource.data.keys().hasOnly([
          'schemaVersion',
          'source',
          'dealRequestId',
          'approvalCode',
          'decision',
          'approver',
          'reason',
          'createdAt',
          'submittedAtClient',
          'page',
          'userAgent'
        ])
        && request.resource.data.schemaVersion == 1
        && request.resource.data.source == 'deal-approval'
        && request.resource.data.dealRequestId is string
        && request.resource.data.dealRequestId.size() >= 8
        && request.resource.data.dealRequestId.size() <= 120
        && request.resource.data.approvalCode is string
        && request.resource.data.approvalCode.size() >= 4
        && request.resource.data.approvalCode.size() <= 80
        && request.resource.data.decision in ['approved', 'rejected']
        && request.resource.data.approver is map
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 800
        && request.resource.data.createdAt is timestamp
        && request.resource.data.submittedAtClient is string
        && request.resource.data.submittedAtClient.size() <= 40
        && request.resource.data.page is string
        && request.resource.data.page.size() <= 300
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 240;
    }

    function isValidAuditEvent() {
      return request.resource.data.keys().hasOnly([
          'schemaVersion',
          'source',
          'eventType',
          'entityType',
          'entityId',
          'message',
          'createdAt',
          'submittedAtClient'
        ])
        && request.resource.data.schemaVersion == 1
        && request.resource.data.source in ['onboarding', 'deal-request', 'deal-approval']
        && request.resource.data.eventType is string
        && request.resource.data.eventType.size() >= 3
        && request.resource.data.eventType.size() <= 80
        && request.resource.data.entityType in ['submission', 'dealRequest', 'dealApproval']
        && request.resource.data.entityId is string
        && request.resource.data.entityId.size() <= 120
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 800
        && request.resource.data.createdAt is timestamp
        && request.resource.data.submittedAtClient is string
        && request.resource.data.submittedAtClient.size() <= 40;
    }
  }
}
